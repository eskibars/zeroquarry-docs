{
  "name": "zeroquarry-docs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "scripts": {
    "sync:openapi": "node scripts/sync-openapi.js",
    "gen:api": "npm run sync:openapi && docusaurus gen-api-docs all && node scripts/prepare-api-sidebar.js",
    "start": "npm run gen:api && docusaurus start --host 0.0.0.0",
    "build": "npm run gen:api && docusaurus build && node scripts/fix-openapi-cjs-exports.js",
    "serve": "docusaurus serve --host 0.0.0.0",
    "screenshots": "node scripts/screenshots/capture.js",
    "screenshots:auth": "node scripts/screenshots/auth.js",
    "screenshots:install": "playwright install chromium",
    "clear": "docusaurus clear && docusaurus clean-api-docs all"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/plugin-content-docs": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.1.1",
    "docusaurus-plugin-openapi-docs": "^5.0.0",
    "docusaurus-theme-openapi-docs": "^5.0.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "overrides": {
    "body-parser": "1.20.3",
    "express": "4.21.2",
    "webpackbar": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
